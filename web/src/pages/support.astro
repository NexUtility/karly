---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    q: "Are my numbers private?",
    a: "Yes. Kârly stores your cost / sell-price inputs only on your device, in local app storage. We do not upload them, sync them to a server, or include them in any analytics event. If you uninstall the app, the data is gone.",
  },
  {
    q: "Which marketplaces are supported?",
    a: "Trendyol, Hepsiburada, n11, Çiçek Sepeti, Pazarama, Amazon US, Etsy, eBay, Shopify, plus a Custom marketplace where you set your own rates. We add new marketplaces based on user requests — write to us with the marketplace name and your country.",
  },
  {
    q: "How accurate are the fee models?",
    a: "We model each marketplace's published default commission, listing, and payment processing fees. Promotional and category-specific overrides are not modelled — if you're in a special program, treat the calculator output as a high-confidence estimate, not a settlement statement.",
  },
  {
    q: "How do I cancel a subscription?",
    a: "Subscriptions are managed by Google Play. Open the Play Store app → tap your profile picture → Payments &amp; subscriptions → Subscriptions → Kârly → Cancel. Cancellation takes effect at the end of the current billing period.",
  },
  {
    q: "Where can I report a bug or request a feature?",
    a: 'Email <a class="inline" href="mailto:hi@nexutility.com">hi@nexutility.com</a> with the app version (Settings → About), your device model, and a description of what happened. Screenshots help. We reply within one business day.',
  },
  {
    q: "What about iOS?",
    a: "Android-first launch. iOS is on the roadmap — it lands after Android revenue covers the Apple Developer Program fee. Write to us if you'd like to be notified.",
  },
];
---

<BaseLayout
  title="Support"
  description="Help and contact options for Kârly. Cancel subscriptions, report bugs, request new marketplaces."
>
  <article class="page legal" data-screen-label="Support">
    <header class="legal-head">
      <span class="eyebrow">Support</span>
      <h1>Real humans,<br />fast replies.</h1>
      <p class="lede">
        Write to us directly, or check the answers to the questions we get
        most often.
      </p>
    </header>

    <div class="support-cards">
      <a class="support-card" href="mailto:hi@nexutility.com">
        <div class="icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M3 8.5V17a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5M3 8.5l8.4 5.6a1 1 0 0 0 1.2 0L21 8.5M3 8.5V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1.5"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </div>
        <h3>General support</h3>
        <p>
          Bugs, billing, account questions, feature requests. We reply within
          1 business day.
        </p>
        <p class="addr num">hi@nexutility.com</p>
      </a>

      <a class="support-card" href="mailto:privacy@nexutility.com">
        <div class="icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M12 3 4 6.5v5c0 4.5 3.2 8.7 8 10 4.8-1.3 8-5.5 8-10v-5L12 3Z"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </div>
        <h3>Privacy &amp; data</h3>
        <p>
          GDPR / KVKK requests, data export, or anything else
          privacy-related.
        </p>
        <p class="addr num">privacy@nexutility.com</p>
      </a>
    </div>

    <h2 style="margin-top: 64px">Frequently asked</h2>
    <div class="faq-grid" style="margin-top: 24px">
      {
        faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <div class="answer" set:html={f.a} />
          </details>
        ))
      }
    </div>
  </article>
</BaseLayout>
