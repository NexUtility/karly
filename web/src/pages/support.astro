---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    q: "Are my numbers private?",
    a: "Yes. Kârly stores your cost / sell-price inputs only on your device, in local app storage. We do not upload them, sync them to a server, or include them in any analytics event. If you uninstall the app, the data is gone.",
  },
  {
    q: "Which marketplaces are supported?",
    a: "Trendyol, Hepsiburada, N11, Amazon, Etsy, eBay, and Shopify at launch. We add new marketplaces based on user requests — write to us with the marketplace name and your country.",
  },
  {
    q: "How accurate are the fee models?",
    a: "We model each marketplace's public commission, listing, and payment processing fees as published by the marketplace itself. Promotional and category-specific overrides are not modelled — if you're in a special program, treat the calculator output as a high-confidence estimate, not a settlement statement.",
  },
  {
    q: "How do I cancel a subscription?",
    a: "Subscriptions (if you have one) are managed by Google Play. Open the Play Store app → tap your profile picture → Payments & subscriptions → Subscriptions → Kârly → Cancel. Cancellation takes effect at the end of the current billing period.",
  },
  {
    q: "Where can I report a bug or request a feature?",
    a: "Email support@nexutility.dev with the app version (Settings → About), your device model, and a description of what happened. Screenshots help. We reply within one business day.",
  },
  {
    q: "What about iOS?",
    a: "Android-first launch. iOS is on the roadmap. If you'd like to be notified when it lands, write to hello@nexutility.dev.",
  },
];
---

<BaseLayout
  title="Support"
  description="Help and contact options for Kârly. Cancel subscriptions, report bugs, request new marketplaces."
>
  <section class="container-page pt-16 pb-10 md:pt-24 md:pb-12">
    <div class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-subtle">Support</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">
        Real humans, fast replies.
      </h1>
      <p class="mt-5 text-fg-muted md:text-lg">
        Write to us directly, or check the answers to the questions we get
        most often.
      </p>
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="grid gap-4 sm:grid-cols-2">
      <a
        href="mailto:support@nexutility.dev"
        class="group rounded-xl border border-border bg-bg-elev/40 p-6 transition-all hover:border-border-strong hover:bg-bg-elev"
      >
        <div
          class="grid h-10 w-10 place-items-center rounded-md bg-accent/10 text-accent"
          aria-hidden="true"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M3 8.5V17a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5M3 8.5l8.4 5.6a1 1 0 0 0 1.2 0L21 8.5M3 8.5V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1.5"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h2 class="mt-5 text-base font-semibold text-fg">General support</h2>
        <p class="mt-1.5 text-sm text-fg-muted">
          Bugs, billing, account questions, feature requests. We reply within
          1 business day.
        </p>
        <p class="mt-4 font-mono text-sm text-fg group-hover:text-accent">
          support@nexutility.dev
        </p>
      </a>

      <a
        href="mailto:privacy@nexutility.dev"
        class="group rounded-xl border border-border bg-bg-elev/40 p-6 transition-all hover:border-border-strong hover:bg-bg-elev"
      >
        <div
          class="grid h-10 w-10 place-items-center rounded-md bg-accent/10 text-accent"
          aria-hidden="true"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M12 3 4 6.5v5c0 4.5 3.2 8.7 8 10 4.8-1.3 8-5.5 8-10v-5L12 3Z"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h2 class="mt-5 text-base font-semibold text-fg">Privacy & data</h2>
        <p class="mt-1.5 text-sm text-fg-muted">
          GDPR / KVKK requests, data export, or anything else privacy-related.
        </p>
        <p class="mt-4 font-mono text-sm text-fg group-hover:text-accent">
          privacy@nexutility.dev
        </p>
      </a>
    </div>
  </section>

  <section class="container-page pb-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-semibold tracking-tight md:text-3xl">
        Frequently asked
      </h2>
      <div class="mt-8 divide-y divide-border rounded-xl border border-border bg-bg-elev/40">
        {
          faqs.map((faq) => (
            <details class="group">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4 p-6 transition-colors hover:bg-bg-elev">
                <span class="text-base font-medium text-fg">{faq.q}</span>
                <span
                  class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md border border-border text-fg-muted transition-transform group-open:rotate-45"
                  aria-hidden="true"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                    <path
                      d="M12 5v14M5 12h14"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                    />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-sm leading-relaxed text-fg-muted">
                {faq.a}
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
