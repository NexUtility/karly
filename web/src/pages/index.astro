---
import BaseLayout from "../layouts/BaseLayout.astro";

const howSteps = [
  {
    step: "01",
    title: "Pick a marketplace",
    body: "Trendyol, Hepsiburada, Amazon, Etsy, eBay — 10 in total. We've already loaded each one's commission, VAT, and any listing fees.",
  },
  {
    step: "02",
    title: "Enter cost & price",
    body: "What you paid for it. What you're listing it at. That's enough to get a real answer. Shipping and ads are optional — tap to expand.",
  },
  {
    step: "03",
    title: "See your net, line by line",
    body: "Margin, ROI, breakeven price, and a plain-language breakdown of every fee. Share a PDF or save it to History to compare later.",
  },
];

const trMarkets = [
  { flag: "🇹🇷", name: "Trendyol", fee: "18% · 20% VAT · ₺" },
  { flag: "🇹🇷", name: "Hepsiburada", fee: "15.5% · 20% VAT · ₺" },
  { flag: "🇹🇷", name: "n11", fee: "13% · 20% VAT · ₺" },
  { flag: "🇹🇷", name: "Çiçek Sepeti", fee: "18% · 20% VAT · ₺" },
  { flag: "🇹🇷", name: "Pazarama", fee: "12% · 20% VAT · ₺" },
];

const globalMarkets = [
  { flag: "🇺🇸", name: "Amazon US", fee: "15% referral · $" },
  { flag: "🇺🇸", name: "Etsy", fee: "6.5% + $0.20 · $" },
  { flag: "🇺🇸", name: "eBay", fee: "13.5% final value · $" },
  { flag: "🌐", name: "Shopify", fee: "2.9% + $0.30 · $" },
  { flag: "⚙", name: "Custom", fee: "Set your own" },
];

const promises = [
  {
    title: "No ads. Ever.",
    body: "We have never wired AdMob, and we never will. Not in Free. Not in Pro. Not later “to support the team.” The number on your screen is the number you came for.",
  },
  {
    title: "No tracking.",
    body: "No analytics SDK. No third-party scripts. Your saved calculations live on your device in your phone's preferences. We don't have a server that stores your data, because we don't have a server.",
  },
  {
    title: "Honest paywall.",
    body: "Pro is exactly three things: unlimited calculations, saved history with filters, and unlimited PDF reports. We don't promise features we haven't built.",
  },
];

const faqs = [
  {
    q: "Why is the free tier capped at 3 calculations a day?",
    a: "Because a real calculator with up-to-date marketplace fees costs us something to maintain, and we refuse to run ads. Three a day is enough to test product ideas casually; if you're listing daily and want History to keep your numbers, Pro pays for itself.",
  },
  {
    q: "Are the commission rates accurate?",
    a: "They are the marketplaces' published default rates. Category-specific tweaks and seller-tier discounts exist — you can override commission and VAT on every calculation, and we'll honor your number.",
  },
  {
    q: "Does Kârly sync with my Etsy / Amazon / Trendyol account?",
    a: "No. Kârly is a manual calculator, not an inventory sync tool. You type the numbers, we do the math. That's also why it works without an internet connection and why your data never leaves your phone.",
  },
  {
    q: "Where does my saved data live?",
    a: "On your phone, in the OS's encrypted preferences store. There is no Kârly account. There is no Kârly server. If you delete the app, your data is gone — which means uninstall &amp; reinstall is the only way to “reset” everything.",
  },
  {
    q: "iPhone version?",
    a: "Coming. Android first — that's where our Turkish seller community actually is. iOS lands after Android revenue covers the Apple Developer Program fee. Honest.",
  },
  {
    q: "I want a feature you don't have. Can I write to you?",
    a: 'Yes — <a class="inline" href="mailto:hi@nexutility.com">hi@nexutility.com</a>. Cross-marketplace SKU comparison, live FX, and per-category commission tables are all on the roadmap; we\'d rather build them based on what you actually need than guess.',
  },
];
---

<BaseLayout
  title="Kârly"
  description="Know what you actually keep. Kârly runs the same math across 10 marketplaces — Trendyol, Etsy, Amazon, eBay and more — so you can decide where to list before you list. No ads. No tracking."
>
  <!-- ── HERO ────────────────────────────────────────────────── -->
  <header class="page hero" data-screen-label="Landing — Hero">
    <div class="hero-grid">
      <div>
        <span class="eyebrow">For dropshippers &amp; online sellers</span>
        <h1>
          Know what<br />
          you <span class="accent">actually</span> keep.
        </h1>
        <p class="lede">
          Type your cost and the price you&rsquo;d list at. Kârly tells you the
          net profit on Trendyol, Etsy, Amazon, eBay — same math, every
          marketplace — so you can decide where to list <em>before</em> you
          list.
        </p>

        <div class="hero-ctas">
          <a class="btn btn-primary" href="#download">
            Get Kârly
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path
                d="M4 7h6m0 0L7 4m3 3L7 10"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
              ></path>
            </svg>
          </a>
          <a class="btn btn-ghost" href="#how">See how it works</a>
        </div>

        <div class="hero-trust">
          <span>No ads, ever</span>
          <span>No tracking</span>
          <span>Free tier is genuinely free</span>
        </div>
      </div>

      <!-- Phone mockup — preview of the calculator -->
      <div class="phone-stage">
        <div
          class="phone"
          role="img"
          aria-label="Kârly mobile app showing the calculator screen"
        >
          <div class="phone-screen">
            <div class="status">
              <span>9:41</span>
              <span>● ●</span>
            </div>
            <div class="phone-app">
              <div class="topbar">
                <span class="km">K</span>
                <span class="ksub">Kârly</span>
              </div>
              <div>
                <h4>New entry</h4>
                <div class="sub-line">Two numbers in, profit out.</div>
              </div>
              <div class="mp-chip">
                <span class="mp-flag">🇹🇷</span>
                <span><strong>Trendyol</strong> · 18% fee · TRY</span>
              </div>
              <div class="item-line">Linen pillow cover · oat</div>
              <div class="twocol">
                <div class="col">
                  <label>What you paid</label>
                  <div class="val">
                    <span class="sym">₺</span><span class="num">180</span>
                  </div>
                </div>
                <div class="col">
                  <label>Selling for</label>
                  <div class="val">
                    <span class="sym">₺</span><span class="num">499</span>
                  </div>
                </div>
              </div>
              <div class="you-keep">
                <div>
                  <div class="lbl">You&rsquo;d keep</div>
                  <div class="amt num">+₺102.48</div>
                </div>
                <div class="pct num">20.5% margin</div>
              </div>
              <div class="cta">See the breakdown</div>
              <div class="tabs">
                <span class="active">Calculate</span>
                <span>History</span>
                <span>Settings</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ── HOW IT WORKS ─────────────────────────────────────────── -->
  <section id="how" class="page" data-screen-label="Landing — How it works">
    <span class="eyebrow">How it works</span>
    <h2>Three taps to a real number.</h2>
    <p class="lede" style="margin-top:18px">
      Most marketplace calculators ask for fifteen fields and still get the
      math wrong. Kârly pre-fills your marketplace&rsquo;s commission and VAT,
      so you only enter what you actually know.
    </p>

    <div class="how-grid">
      {
        howSteps.map((s) => (
          <div class="how-card">
            <span class="how-step">{s.step}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ── MARKETPLACES ─────────────────────────────────────────── -->
  <section
    id="markets"
    class="markets"
    data-screen-label="Landing — Marketplaces"
  >
    <div class="page">
      <span class="eyebrow">Marketplaces</span>
      <h2>Ten marketplaces.<br />One calculator.</h2>
      <p class="lede" style="margin-top:18px">
        Cross-border selling is the wedge. Most calculators handle Etsy <em>or</em>
        Trendyol, never both. Kârly handles both — and then some.
      </p>

      <div class="region-tag" style="margin-top:48px">Türkiye</div>
      <div class="markets-grid">
        {
          trMarkets.map((m) => (
            <div class="market-card">
              <div class="flag">{m.flag}</div>
              <div class="name">{m.name}</div>
              <div class="fee">{m.fee}</div>
            </div>
          ))
        }
      </div>

      <div class="region-tag" style="margin-top:40px">Global</div>
      <div class="markets-grid">
        {
          globalMarkets.map((m) => (
            <div class="market-card">
              <div class="flag">{m.flag}</div>
              <div class="name">{m.name}</div>
              <div class="fee">{m.fee}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── PROMISES ─────────────────────────────────────────────── -->
  <section class="page" id="promises" data-screen-label="Landing — Promises">
    <div class="promises">
      <span class="eyebrow" style="color: var(--accent)">What we won&rsquo;t do</span>
      <h2>Three things we&rsquo;ll <span class="accent">never</span> do to you.</h2>
      <p class="lede">
        Free tools have a habit of selling you out for ad pennies. Kârly is
        the opposite — your numbers are yours, your phone stays clean, and we
        tell you exactly what Pro gives you.
      </p>

      <div class="promises-grid">
        {
          promises.map((p) => (
            <div class="promise">
              <h4>{p.title}</h4>
              <p>{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── PRICING ──────────────────────────────────────────────── -->
  <section id="pricing" class="page" data-screen-label="Landing — Pricing">
    <span class="eyebrow">Pricing</span>
    <h2>Free is free.<br />Pro is small.</h2>
    <p class="lede" style="margin-top:18px">
      Run a few calculations a day to test product ideas — free, forever. List
      enough to want a history of your math? Pro is $1.66 a month.
    </p>

    <div class="pricing-grid">
      <div class="price-card">
        <span class="tier">Free</span>
        <div class="amount">$0<small>/forever</small></div>
        <div class="sub-amount">No card. No ads.</div>
        <ul class="price-bullets">
          <li>All 10 marketplaces, all the math</li>
          <li>3 calculations per day</li>
          <li>Unlimited PDF reports of what you calculated</li>
          <li>Light + dark, English + Türkçe</li>
        </ul>
        <a class="pcta ghost" href="#download">Start free</a>
      </div>
      <div class="price-card featured">
        <span class="save-pill">Save 44%</span>
        <span class="tier">Pro · Annual</span>
        <div class="amount">$1.66<small>/mo</small></div>
        <div class="sub-amount">Billed $19.99 yearly. Or $2.99/month.</div>
        <ul class="price-bullets">
          <li><strong>Everything in Free</strong>, plus —</li>
          <li>Unlimited calculations (no daily cap)</li>
          <li>History: every calculation, tagged + searchable</li>
          <li>Filter by marketplace, category, profit, or date</li>
          <li>Compare the same product across all 10 marketplaces</li>
        </ul>
        <a class="pcta primary" href="#download">Get Pro</a>
      </div>
    </div>

    <p
      style="text-align:center; color: var(--subtle); font-size: 13px; margin-top: 28px"
    >
      3 days free · cancel anytime · no auto-charge surprises
    </p>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────────── -->
  <section class="page" data-screen-label="Landing — FAQ">
    <span class="eyebrow">Honest answers</span>
    <h2>Things people actually ask.</h2>

    <div class="faq-grid">
      {
        faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <div class="answer" set:html={f.a} />
          </details>
        ))
      }
    </div>
  </section>

  <!-- ── BIG CTA ──────────────────────────────────────────────── -->
  <section
    id="download"
    class="page big-cta"
    data-screen-label="Landing — Download"
  >
    <h2>Stop guessing.<br />Start <span class="accent">knowing.</span></h2>
    <p class="lede">
      Free to download. Free to keep. Three calculations a day is genuinely
      enough to try every product idea you&rsquo;ve been sitting on.
    </p>

    <div class="store-row">
      <a class="store-badge" href="#" aria-label="Get it on Google Play">
        <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M5 3.5l11 8.5-11 8.5V3.5z" opacity=".9"></path>
          <path d="M5 3.5l11 8.5-7.5 4.5L5 3.5z" opacity=".7"></path>
          <path d="M16 12l3.5-2-3.5 8L12.5 14 16 12z" opacity=".5"></path>
        </svg>
        <span>
          <span class="top">GET IT ON</span>
          <span class="bot">Google Play</span>
        </span>
      </a>
      <span class="store-badge disabled" aria-label="Coming soon on App Store">
        <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M17.05 12.5c0-2.7 2.2-4 2.3-4-.3-1.8-3.1-2-4-2-1.7-.2-3.3 1-4.2 1-.9 0-2.2-1-3.7-1-2 .1-3.7 1.2-4.7 3-2 3.5-.5 8.6 1.4 11.4.9 1.4 2 3 3.4 2.9 1.4-.1 1.9-.9 3.6-.9s2.2.9 3.6.9c1.5 0 2.5-1.4 3.4-2.8.7-1 1.3-2.2 1.6-3.3-1.9-.8-3.7-3-3.7-5.2zM14.8 5.4c.8-.9 1.3-2.2 1.2-3.4-1.1.1-2.4.7-3.2 1.6-.7.8-1.4 2.1-1.2 3.3 1.2.1 2.4-.6 3.2-1.5z"
          ></path>
        </svg>
        <span>
          <span class="top">COMING SOON ON</span>
          <span class="bot">App Store</span>
        </span>
      </span>
    </div>
  </section>
</BaseLayout>
