---
import BaseLayout from "../layouts/BaseLayout.astro";

const calculations = [
  {
    title: "Net profit",
    body: "Per unit and per batch, after every commission, transaction fee, shipping cost, and tax.",
  },
  {
    title: "Profit margin",
    body: "What you actually keep, as a percentage of the sell price — not the manufacturer marketing version.",
  },
  {
    title: "ROI",
    body: "Return on the capital you tie up per unit. Useful when comparing thin-margin volume to thicker margins.",
  },
  {
    title: "Breakeven price",
    body: "The minimum sell price that still covers cost, fees, and operational overhead. The line below which you lose money.",
  },
];

const marketplaces = [
  "Trendyol",
  "Hepsiburada",
  "N11",
  "Amazon",
  "Etsy",
  "eBay",
  "Shopify",
];

const principles = [
  {
    title: "Honest numbers",
    body: "Every fee modelled — listing, commission, payment processing, return reserve. The number you see is the number you'll see in your settlement.",
  },
  {
    title: "Cross-border native",
    body: "Currency-aware. Set sell price in USD/EUR/TRY and Kârly handles the conversion at your chosen FX rate.",
  },
  {
    title: "On-device, private",
    body: "Calculations run locally. Your costs and margins never leave your phone. No accounts, no sync, no analytics on numbers.",
  },
  {
    title: "Fast, not fancy",
    body: "Pick marketplace, type cost, type sell price, see profit. Three fields, one screen. No setup.",
  },
];
---

<BaseLayout title="Kârly">
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-bg" aria-hidden="true"></div>
    <div
      class="absolute -top-32 left-1/2 h-[480px] w-[680px] -translate-x-1/2 rounded-full bg-accent/10 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative pt-24 pb-24 md:pt-32 md:pb-32">
      <div class="mx-auto max-w-3xl text-center">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-border bg-bg-elev/60 px-3 py-1 text-xs font-mono text-fg-muted backdrop-blur"
        >
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
          </span>
          Coming to Google Play
        </span>

        <h1
          class="mt-6 text-balance text-5xl font-semibold leading-[1.05] tracking-tight md:text-7xl"
        >
          <span class="text-gradient">Know your real profit</span>
          <br />
          before the listing goes live.
        </h1>

        <p class="mx-auto mt-7 max-w-xl text-pretty text-base leading-relaxed text-fg-muted md:text-lg">
          Kârly is a profit calculator for marketplace sellers. Pick a
          marketplace, plug in your cost and sell price, see net margin, ROI,
          and breakeven in seconds — every fee already modelled.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <span
            class="inline-flex items-center gap-2 rounded-md border border-border bg-bg-elev/60 px-5 py-2.5 text-sm font-medium text-fg-muted"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 20.5V3.5a.5.5 0 0 1 .75-.4l13.5 8.5a.5.5 0 0 1 0 .8l-13.5 8.5a.5.5 0 0 1-.75-.4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
            </svg>
            Google Play — soon
          </span>
          <a
            href="/support"
            class="inline-flex items-center gap-1.5 rounded-md border border-border bg-bg-elev/60 px-5 py-2.5 text-sm font-medium text-fg backdrop-blur transition-colors hover:border-border-strong hover:bg-bg-elev"
          >
            Get notified
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IT CALCULATES -->
  <section class="container-page py-20 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">What it does</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        Four numbers that actually matter.
      </h2>
      <p class="mt-4 text-fg-muted">
        Skip the spreadsheet. These are the metrics Kârly returns every time
        you change a field.
      </p>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-xl border border-border bg-border md:grid-cols-2">
      {
        calculations.map((c, i) => (
          <div class="bg-bg-elev/40 p-7 transition-colors hover:bg-bg-elev">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-fg-muted">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="h-px flex-1 bg-border"></div>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-fg">{c.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-fg-muted">{c.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- MARKETPLACES -->
  <section class="container-page py-20 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">
        Marketplaces
      </p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        Fee models for the platforms you actually sell on.
      </h2>
      <p class="mt-4 text-fg-muted">
        Pre-loaded with current commission rates, payment processing fees,
        and listing costs for each marketplace below.
      </p>
    </div>

    <ul
      class="mx-auto mt-12 flex max-w-3xl flex-wrap items-center justify-center gap-2"
    >
      {
        marketplaces.map((m) => (
          <li class="rounded-full border border-border bg-bg-elev/40 px-4 py-2 text-sm text-fg-muted transition-colors hover:border-border-strong hover:bg-bg-elev hover:text-fg">
            {m}
          </li>
        ))
      }
      <li class="rounded-full border border-border bg-bg/40 px-4 py-2 text-sm font-mono text-fg-muted">
        + more
      </li>
    </ul>
  </section>

  <!-- PRINCIPLES -->
  <section class="container-page py-20 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">How we built it</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        A pragmatist's calculator.
      </h2>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-xl border border-border bg-border md:grid-cols-2">
      {
        principles.map((p, i) => (
          <div class="bg-bg-elev/40 p-7 transition-colors hover:bg-bg-elev">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-fg-muted">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="h-px flex-1 bg-border"></div>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-fg">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-fg-muted">{p.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- LEGAL CTA -->
  <section class="container-page py-20 md:py-24">
    <div
      class="overflow-hidden rounded-2xl border border-border bg-gradient-to-br from-bg-elev to-bg-elev/40 p-8 md:p-12"
    >
      <div class="grid gap-8 md:grid-cols-[1.6fr_1fr] md:items-center">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">
            Transparency
          </p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
            What we do — and don't — collect.
          </h2>
          <p class="mt-4 max-w-xl text-fg-muted">
            Kârly stores your numbers on your device, not on a server. We
            disclose every SDK we use and every piece of data Google AdMob
            and RevenueCat handle on our behalf.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <a
            href="/privacy"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Privacy Policy</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
          <a
            href="/terms"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Terms of Service</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
          <a
            href="/support"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Support</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
