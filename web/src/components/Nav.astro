---
// Sticky-blur nav with brand mark + section anchors + accent CTA.
// On legal/support pages the anchors target index.astro#section.
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = path === "/";
const prefix = isHome ? "" : "/";

const links = [
  { href: `${prefix}#how`, label: "How it works" },
  { href: `${prefix}#markets`, label: "Marketplaces" },
  { href: `${prefix}#pricing`, label: "Pricing" },
  { href: `${prefix}#promises`, label: "Promises" },
];
---

<nav class="nav" data-screen-label="Site nav">
  <div class="nav-inner">
    <a class="brand" href="/" aria-label="Kârly — home">
      <span class="brand-mark" aria-hidden="true">K</span>
      <span>Kârly</span>
    </a>
    <div class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={`${prefix}#download`} class="nav-cta">
        Get the app
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path
            d="M3 6h6m0 0L6 3m3 3L6 9"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</nav>
