---
// Calm footer — brand on the left, inline link list, fine print below.
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = path === "/";
const prefix = isHome ? "" : "/";
const year = new Date().getFullYear();
---

<footer class="site-footer" data-screen-label="Site footer">
  <div class="page">
    <div class="row">
      <a class="brand" href="/" aria-label="Kârly — home">
        <span class="brand-mark" aria-hidden="true">K</span>
        <span>Kârly</span>
      </a>
      <div class="links">
        <a href={`${prefix}#how`}>How it works</a>
        <a href={`${prefix}#markets`}>Marketplaces</a>
        <a href={`${prefix}#pricing`}>Pricing</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/support">Support</a>
      </div>
    </div>
    <p class="fine">
      Kârly is a product of NexUtility. Made for small sellers who want a
      clear number, not a sales pitch. The marketplace names &amp; logos
      referenced here belong to their respective owners — Kârly isn&rsquo;t
      affiliated with or endorsed by any of them.
      <br /><br />
      © {year} NexUtility · v0.2
    </p>
  </div>
</footer>
