---
const year = new Date().getFullYear();
const sections = [
  {
    title: "Product",
    links: [
      { href: "/", label: "Overview" },
      { href: "/support", label: "Support" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/privacy", label: "Privacy Policy" },
      { href: "/terms", label: "Terms of Service" },
    ],
  },
];
---

<footer class="mt-32 border-t border-border/60">
  <div class="container-page py-16">
    <div class="grid gap-12 md:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight">
          <span class="grid h-7 w-7 place-items-center rounded-md bg-accent text-accent-foreground font-mono text-sm font-bold">
            ₺
          </span>
          <span>Kârly</span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-fg-muted">
          A cross-border marketplace seller profit calculator. Built by
          <a
            href="https://nexutility.dev"
            class="text-fg underline-offset-4 hover:underline"
            rel="noopener"
          >
            NexUtility
          </a>.
        </p>
        <p class="mt-3 max-w-xs text-xs text-fg-subtle">
          Questions?
          <a
            href="mailto:support@nexutility.dev"
            class="text-fg-muted underline-offset-4 hover:text-fg hover:underline"
          >
            support@nexutility.dev
          </a>
        </p>
      </div>

      {
        sections.map((section) => (
          <div>
            <h3 class="text-sm font-medium text-fg">{section.title}</h3>
            <ul class="mt-4 space-y-2.5">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-fg-muted underline-offset-4 transition-colors hover:text-fg hover:underline"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-border/60 pt-6 text-xs text-fg-subtle sm:flex-row sm:items-center"
    >
      <p>© {year} NexUtility. All rights reserved.</p>
      <p class="font-mono">v0.1.0 · built with Astro on Cloudflare</p>
    </div>
  </div>
</footer>
