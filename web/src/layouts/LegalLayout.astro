---
import BaseLayout from "./BaseLayout.astro";

interface Section {
  id: string;
  title: string;
}

interface Props {
  eyebrow: string;
  title: string;
  lede: string;
  description?: string;
  lastUpdated: string;
  meta?: string[]; // extra meta lines beside "Last updated"
  sections: Section[];
}

const {
  eyebrow,
  title,
  lede,
  description,
  lastUpdated,
  meta = [],
  sections,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="page legal" data-screen-label={`${title} — Content`}>
    <header class="legal-head">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p class="lede">{lede}</p>
      <div class="meta">
        <span>Last updated · {lastUpdated}</span>
        {meta.map((m) => <span>{m}</span>)}
      </div>
    </header>

    <div class="legal-body">
      <aside class="toc" aria-label="Sections">
        <strong>On this page</strong>
        {sections.map((s) => <a href={`#${s.id}`}>{s.title}</a>)}
      </aside>

      <div class="legal-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
